{
  "name": "automation-playwright-ts-pom",
  "version": "1.0.0",
  "description": "Playwright + TypeScript automation demo with POM and Slack alerts",
  "scripts": {
    "test": "playwright test --project=chromium",
    "test:all-browsers": "playwright test",
    "test:chromium": "playwright test --project=chromium",
    "test:smoke": "playwright test --grep @smoke --project=chromium",
    "test:smoke:all-browsers": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression --project=chromium",
    "test:regression:all-browsers": "playwright test --grep @regression",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --headed --debug",
    "test:report": "playwright show-report",
    "typecheck": "tsc --noEmit",
    "smoke:alert": "node scripts/run-and-alert.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "dotenv": "^17.4.1"
  }
}
